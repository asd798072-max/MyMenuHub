local function StartScript()
    getgenv().Settings = { Silent = false, Tracer = false, FovCircle = false, FovRadius = 150, Prediction = 0.165, KillCheck = true }
    local Count = 0
    local function CreateBtn(name, setting)
        local btn = Instance.new("TextButton", MainFrame); btn.Size = UDim2.new(1, 0, 0, 40); btn.Position = UDim2.new(0, 0, 0, Count * 45)
        btn.Text = name .. ": OFF"; btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); btn.TextColor3 = Color3.new(1,1,1)
        btn.MouseButton1Click:Connect(function()
            getgenv().Settings[setting] = not getgenv().Settings[setting]
            btn.Text = name .. ": " .. (getgenv().Settings[setting] and "ON" or "OFF")
        end)
        Count = Count + 1
    end
    CreateBtn("Silent", "Silent"); CreateBtn("Tracer", "Tracer"); CreateBtn("FOV Circle", "FovCircle"); CreateBtn("Kill Check", "KillCheck")

    local Hook; Hook = hookmetamethod(game, "__namecall", function(self, ...)
        local Args = {...}
        if getgenv().Settings.Silent and getnamecallmethod() == "FireServer" then
            local Target = nil 
            if Target then Args[1] = Target.Position; return self.FireServer(self, unpack(Args)) end
        end
        return Hook(self, ...)
    end)
end

SubmitBtn.MouseButton1Click:Connect(function()
